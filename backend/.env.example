# ==============================================================================
# Document Processing API - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your actual credentials.
# ==============================================================================

# --- Application Settings ---
DEBUG=False
APP_NAME="Document Processing API"
FRONTEND_URL="http://localhost:5173"

# --- Security & CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- Database Settings (PostgreSQL) ---
# Example for local Postgres: postgresql://user:password@localhost:5432/dbname
# Example for Neon: postgresql://user:password@subdomain.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/docproc"

# --- Redis Settings ---
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# --- RabbitMQ Settings ---
# Option 1: Provide complete connection URL
# RABBITMQ_URL="amqp://user:password@localhost:5672/vhost"
# Option 2: Provide individual connection parameters (used if RABBITMQ_URL not set)
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USER="guest"
RABBITMQ_PASSWORD="guest"
RABBITMQ_VHOST="/"

# --- Celery Settings ---
# Leave empty to automatically use RabbitMQ for broker and Redis for result backend
# CELERY_BROKER_URL="amqp://guest:guest@localhost:5672/"
# CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# --- Clerk Authentication ---
# Get these from your Clerk Dashboard (Settings -> API Keys)
CLERK_SECRET_KEY="sk_test_..."
CLERK_FRONTEND_API="https://..."

# --- File Storage Settings ---
# Options: "local" or "s3"
STORAGE_TYPE="local"
LOCAL_STORAGE_PATH="./storage"

# --- AWS S3 Settings (Required if STORAGE_TYPE=s3) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION="us-east-1"

# --- Processing Limits ---
# Max upload size in bytes (default 50MB)
MAX_UPLOAD_SIZE=52428800
MAX_FILES_PER_UPLOAD=10
TASK_TIMEOUT=1800
MAX_RETRIES=3

# --- Concurrency Controls (Deadlock Fix) ---
# Prisma connection pool size
PRISMA_POOL_SIZE=20
# Prisma connection pool timeout in seconds
PRISMA_POOL_TIMEOUT=30
# Individual Prisma operation timeout in seconds
PRISMA_OPERATION_TIMEOUT=10
# Total task timeout in seconds (15 minutes)
TASK_TOTAL_TIMEOUT=900
# Maximum pending documents before rejecting batch uploads
BATCH_UPLOAD_MAX_QUEUE_DEPTH=50
# Maximum concurrent batch upload tasks
BATCH_UPLOAD_MAX_CONCURRENT_TASKS=5

# --- Task Enqueue Retry Configuration ---
# Number of retry attempts for task enqueuing
TASK_ENQUEUE_MAX_RETRIES=3
# Delay between retry attempts in seconds (exponential backoff applied)
TASK_ENQUEUE_RETRY_DELAY=1

# --- Scheduler Configuration (Automatic Task Scheduler) ---
# Seconds between health checks (5-300)
SCHEDULER_HEALTH_CHECK_INTERVAL=20
# Maximum concurrent processing tasks (1-20)
SCHEDULER_MAX_CONCURRENCY=4
# Seconds before document considered stuck (minimum 60)
SCHEDULER_STUCK_THRESHOLD=300
# Queue depth warning threshold
SCHEDULER_QUEUE_WARNING=20
# Queue depth error threshold
SCHEDULER_QUEUE_ERROR=50
